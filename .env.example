VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_PUBLISHABLE_OR_ANON_KEY

# Endast MCP-servern. Dessa får aldrig börja med VITE_ eller skickas till webbläsaren.
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
ORBIT_USER_ID=THE_AUTH_USER_ID_OWNING_THIS_MCP

# Framtida integrations-worker/OAuth-callbacks. Lägg riktiga värden i hostingens secrets.
GOOGLE_CLIENT_ID=YOUR_GOOGLE_OAUTH_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_OAUTH_CLIENT_SECRET
GOOGLE_REDIRECT_URI=https://YOUR_DOMAIN.com/api/integrations/google/callback
SLACK_CLIENT_ID=YOUR_SLACK_CLIENT_ID
SLACK_CLIENT_SECRET=YOUR_SLACK_CLIENT_SECRET
SLACK_SIGNING_SECRET=YOUR_SLACK_SIGNING_SECRET
SLACK_REDIRECT_URI=https://YOUR_DOMAIN.com/api/integrations/slack/callback
